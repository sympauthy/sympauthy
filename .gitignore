# Local configuration file
config/*.yml

# Local H2 database
*.mv.db
*.trace.db

.gradle
**/build/
!core/src/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Bundled UI assets (injected by CI)
server/src/main/resources/sympauthy-flow/*
!server/src/main/resources/sympauthy-flow/.gitkeep
server/src/main/resources/sympauthy-admin/*
!server/src/main/resources/sympauthy-admin/.gitkeep

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath
